generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                  String    @id @default(cuid())
  phone               String?   @unique
  email               String?   @unique
  name                String?
  role                String    @default("bd_strategist")
  tier                String    @default("free")
  phoneVerified       Boolean   @default(false) @map("phone_verified")
  phoneVerificationCode String?  @map("phone_verification_code")
  phoneVerificationExpiry DateTime? @map("phone_verification_expiry")
  smsConsent          Boolean   @default(false) @map("sms_consent")
  smsConsentAt        DateTime? @map("sms_consent_at")
  smsConsentText      String?   @map("sms_consent_text")
  termsAcceptedAt     DateTime? @map("terms_accepted_at")
  stripeCustomerId    String?   @map("stripe_customer_id")
  stripeSubscriptionId String?  @map("stripe_subscription_id")
  createdAt           DateTime  @default(now()) @map("created_at")

  sessions      Session[]
  monthlyUsages MonthlyUsage[]
  smsLogs       SmsLog[]

  @@map("users")
}

model Session {
  id             String   @id @default(cuid())
  userId         String?  @map("user_id")
  anonymousId   String?  @map("anonymous_id")
  verticalName   String   @map("vertical_name")
  verticalContext Json?   @map("vertical_context")
  valueOffer     Json?    @map("value_offer")
  scripts        Json?    @map("scripts")
  model          String   @default("gpt-4o-mini")
  messageCount   Int      @default(0) @map("message_count")
  status         String   @default("discovering")
  nicheSlug      String?  @map("niche_slug")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  user     User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  niche    Niche?   @relation(fields: [nicheSlug], references: [slug], onDelete: SetNull)
  messages Message[]

  @@index([nicheSlug])
  @@map("sessions")
}

model Niche {
  slug                String   @id
  country             String   @default("US") @map("country")
  countryCode         String   @default("+1") @map("country_code")
  headline            String
  subhead             String
  bodyCopy           String   @map("body_copy")
  heroImage           String?  @map("hero_image")
  heroVideo           String?  @map("hero_video")
  exampleOffer        Json?    @map("example_offer")
  verticalSeedContext Json?   @map("vertical_seed_context")
  metaTitle           String?  @map("meta_title")
  metaDescription     String?  @map("meta_description")
  active              Boolean  @default(true)
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  sessions Session[]

  @@index([country])
  @@map("niches")
}

model Message {
  id        String   @id @default(cuid())
  sessionId String   @map("session_id")
  role      String
  content   String
  phase     String   @default("discovery")
  createdAt DateTime @default(now()) @map("created_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@map("messages")
}

model MonthlyUsage {
  id           String @id @default(cuid())
  userId       String? @map("user_id")
  anonymousId  String? @map("anonymous_id")
  month        Int
  sessionCount Int    @default(1) @map("session_count")

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, month])
  @@unique([anonymousId, month])
  @@map("monthly_usages")
}

model SmsLog {
  id         String   @id @default(cuid())
  userId     String?  @map("user_id")
  phone      String
  type       String
  message    String
  providerId String?  @map("provider_id")
  status     String
  createdAt  DateTime @default(now()) @map("created_at")

  user       User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("sms_logs")
}

model AppSettings {
  id    String @id @default("default")
  model String @default("gpt-4o-mini")

  @@map("app_settings")
}